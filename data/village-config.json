// Au tout début d'app.js (ou juste avant render/init)
let REMOTE_CFG = {};

async function loadVillageConfig(){
  try {
    const res = await fetch('./data/village-config.json?ts=' + Date.now());
    if (!res.ok) throw new Error('HTTP ' + res.status);
    REMOTE_CFG = await res.json();

    // Exemple : si tu veux alimenter VILLAGE_RULES à partir du JSON
    // Attendu: { "BALENGOU": { chief:"", marketDay:"", forbiddenTradIdx:[...], moreInfos:"" }, ... }
    // Ici, on ne fait *que* la partie couleurs (interdits/marché) à titre d’exemple :
    if (REMOTE_CFG["BALENGOU"]) {
      VILLAGE_RULES["BALENGOU"] = {
        forbiddenTradIdx: REMOTE_CFG["BALENGOU"].forbiddenTradIdx || [],
        marketTradIdx:    (REMOTE_CFG["BALENGOU"].marketTradIdx || []), // si tu ajoutes ce champ côté Excel/JSON
        // marketWeekday:  ...        // si tu veux piloter par jour de semaine
      };
    }
    // Idem pour les autres villages => boucle si tu veux tout synchroniser
  } catch(e){
    console.warn('Config villages non chargée :', e);
  }
}

// Dans DOMContentLoaded (avant render()):
await loadVillageConfig();


